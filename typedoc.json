{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/code"],
  "entryPointStrategy": "expand",
  "alwaysCreateEntryPointModule": false,
  "exclude": ["./src/code/index.ts"],
  "out": "./docs",
  "name": "dot-net-date-number-formatting",
  "includeVersion": true,
  "readme": "README.md",
  "projectDocuments": [
    "./docs-src/guides/getting-started.md",
    "./docs-src/guides/datetime-formatting.md",
    "./docs-src/guides/numeric-formatting.md",
    "./docs-src/guides/number-parsing.md",
    "./docs-src/guides/locales.md",
    "./docs-src/guides/advanced-examples.md"
  ],
  "router": "structure-dir",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "skipErrorChecking": false,
  "cleanOutputDir": true,
  "githubPages": true,
  "hideGenerator": true,
  "searchInComments": true,
  "searchInDocuments": true,
  "hostedBaseUrl": "https://pbkware.github.io/dot-net-date-number-formatting/",
  "navigationLinks": {
    "GitHub": "https://github.com/pbkware/dot-net-date-number-formatting",
    "NPM": "https://www.npmjs.com/package/@pbkware/dot-net-date-number-formatting"
    // "Sponsors": "https://pbkware.github.io/dot-net-date-number-formatting/Overview/Sponsors/",
  }
}
