{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./lib"
  },
  // "include": ["src/**/*.ts", "tests/**/*.ts"]
  "include": ["src/**/*.ts"]
}
